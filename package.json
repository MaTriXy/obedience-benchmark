{
  "name": "obedience-benchmark",
  "version": "0.1.0",
  "description": "Claude Code plugin for benchmarking AI agent obedience to prescribed processes",
  "type": "module",
  "main": "plugin/plugin.json",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "validate-tasks": "node scripts/validate-tasks.js",
    "lint": "eslint . --ext .ts,.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "benchmark",
    "obedience",
    "claude-code",
    "ai-agent",
    "process-fidelity"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "ulid": "^2.3.0",
    "yaml": "^2.3.0"
  }
}
